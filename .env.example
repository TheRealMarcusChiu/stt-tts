# Compute device for all engines: auto | cuda | cpu
DEVICE=auto

# Server bind
HOST=0.0.0.0
PORT=8000

# --- Speech-to-text (faster-whisper) ---
DEFAULT_STT_MODEL=large-v3-turbo
# Comma-separated allowlist of models a request may select.
STT_MODELS=large-v3-turbo,large-v3,distil-large-v3,medium,small,base,tiny
# CTranslate2 compute type: default | float16 | int8 | int8_float16 | float32
STT_COMPUTE_TYPE=default
STT_VAD_FILTER=true
STT_BEAM_SIZE=5
# Allow any faster-whisper model id (not just the allowlist above).
STT_ALLOW_ANY_MODEL=false

# --- Text-to-speech ---
DEFAULT_TTS_MODEL=kokoro
TTS_MODELS=kokoro,piper
DEFAULT_VOICE=af_heart
# Kokoro language: a=US-EN b=GB-EN e=es f=fr h=hi i=it j=ja p=pt-BR z=zh
KOKORO_LANG_CODE=a
# Directory holding Piper <voice>.onnx (+ .onnx.json) files.
PIPER_VOICES_DIR=/models/piper
PIPER_DEFAULT_VOICE=en_US-lessac-medium

# Where faster-whisper caches downloaded model weights.
MODEL_CACHE_DIR=/models/whisper
